{
    "name": "gd-client",
    "version": "0.1.0",
    "description": "Client to interact with the Geometry Dash API",
    "types": "typings/index.d.ts",
    "exports": {
        ".": "./lib/index.js",
        "./util": "./lib/util/index.js"
    },
    "scripts": {
        "build": "npm run lint && tsc",
        "docgen": "typedoc --watch",
        "lint": "eslint src",
        "prettier": "prettier ./src --write",
        "prepare": "husky install",
        "knip": "knip"
    },
    "dependencies": {
        "axios": "^1.16.1"
    },
    "author": "DiversenSato",
    "license": "MIT",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "https://github.com/demonladder/gd-client.git"
    },
    "keywords": [
        "geometry-dash",
        "gd",
        "client"
    ],
    "devDependencies": {
        "@eslint/js": "^9.39.4",
        "@types/bun": "^1.3.14",
        "@types/node": "^25.8.0",
        "eslint": "^9.39.4",
        "husky": "^9.1.7",
        "knip": "^6.13.1",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.3",
        "rimraf": "^6.1.3",
        "typedoc": "^0.28.19",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.3"
    },
    "lint-staged": {
        "*.ts": "prettier --write"
    }
}
