{
    "compilerOptions": {
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "nodenext",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,

        "strict": true,
        "skipLibCheck": true,
        "noImplicitAny": true,
        "noUnusedParameters": true,
        "noUnusedLocals": true,

        "outDir": "lib",
        "declarationDir": "typings",
        "declaration": true,
    },
    "include": [
        "src/**/*",
    ],
}