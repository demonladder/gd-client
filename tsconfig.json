{
    "compilerOptions": {
        "target": "ESNext",
        "module": "esnext",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "isolatedModules": true,

        "strict": true,
        "skipLibCheck": true,
        "noImplicitAny": true,
        "noUnusedParameters": true,
        "noUnusedLocals": true,

        "rootDir": "./src",
        "outDir": "lib",
        "declarationDir": "typings",
        "declaration": true,
        "types": ["bun"]
    },
    "include": [
        "src/**/*",
    ],
}